# GitHub Packages Configuration for @gaqno-development
# This file configures npm to use GitHub Packages for @gaqno-development scope
# Set NPM_TOKEN (e.g. workspace .env); npm substitutes ${NPM_TOKEN} in _authToken
# 
# To create a token: https://github.com/settings/tokens
# Required scopes: read:packages

@gaqno-development:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}
